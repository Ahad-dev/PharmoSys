<UserControl x:Class="PharmoSys.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PharmoSys.ViewModels.Dashboard"
             Background="#F5F6FA" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📊 Overview Dashboard" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Top Metrics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Today's Sales -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Today's Sales" FontSize="14" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalSalesToday, StringFormat='PKR {0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#16A085" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Total Orders -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Orders Today" FontSize="14" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalOrdersToday}" FontSize="24" FontWeight="Bold" Foreground="#2980B9" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Low Stock -->
            <Border Grid.Column="4" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Low Stock Items" FontSize="14" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LowStockItems}" FontSize="24" FontWeight="Bold" Foreground="#E67E22" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Expiring Soon -->
            <Border Grid.Column="6" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Expiring Soon" FontSize="14" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ExpiringItems}" FontSize="24" FontWeight="Bold" Foreground="#C0392B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alerts Section -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Low Stock Grid -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⚠️ Critical Low Stock" FontSize="18" FontWeight="SemiBold" Foreground="#E67E22" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding LowStockProducts}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" BorderThickness="0" Background="White" GridLinesVisibility="None" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding StockQuantity, StringFormat='Qty: {0}'}" Width="60" Foreground="#C0392B"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Expiring Grid -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⏳ Expiring Soon (30 Days)" FontSize="18" FontWeight="SemiBold" Foreground="#C0392B" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ExpiringProducts}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" BorderThickness="0" Background="White" GridLinesVisibility="None" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding ExpiryDate, StringFormat='dd MMM yyyy'}" Width="90" Foreground="#C0392B"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
