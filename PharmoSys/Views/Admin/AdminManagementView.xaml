<UserControl x:Class="PharmoSys.Views.Admin.AdminManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PharmoSys.ViewModels.Admin"
             Background="#F5F6FA" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:AdminManagementViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="⚙️ Admin Management" Style="{StaticResource Heading2}" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Manage users, suppliers, and application settings." Style="{StaticResource Subtitle}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}" Padding="0,10,0,0">
            
            <!-- USERS TAB -->
            <TabItem Header="👥 Users" Style="{StaticResource ModernTabItem}">
                <Border Style="{StaticResource ModernCard}" Margin="0,10,0,0" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="➕ Add User" Command="{Binding AddUserCommand}" Style="{StaticResource InfoButton}" Margin="0,0,10,0"/>
                            <Button Content="✏️ Edit" Command="{Binding EditUserCommand}" CommandParameter="{Binding SelectedItem, ElementName=UserGrid}" Style="{StaticResource WarningButton}" Margin="0,0,10,0"/>
                            <Button Content="🗑️ Delete" Command="{Binding DeleteUserCommand}" CommandParameter="{Binding SelectedItem, ElementName=UserGrid}" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                            <Button Content="↻ Refresh" Command="{Binding LoadDataCommand}" Style="{StaticResource OutlineButton}"/>
                        </StackPanel>

                        <DataGrid x:Name="UserGrid" Grid.Row="1" ItemsSource="{Binding Users}" Style="{StaticResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="200"/>
                                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="150"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role.RoleName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- SUPPLIERS TAB -->
            <TabItem Header="🚚 Suppliers" Style="{StaticResource ModernTabItem}">
                <Border Style="{StaticResource ModernCard}" Margin="0,10,0,0" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="➕ Add Supplier" Command="{Binding AddSupplierCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                            <Button Content="✏️ Edit" Command="{Binding EditSupplierCommand}" CommandParameter="{Binding SelectedItem, ElementName=SupplierGrid}" Style="{StaticResource WarningButton}" Margin="0,0,10,0"/>
                            <Button Content="🗑️ Delete" Command="{Binding DeleteSupplierCommand}" CommandParameter="{Binding SelectedItem, ElementName=SupplierGrid}" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                            <Button Content="↻ Refresh" Command="{Binding LoadDataCommand}" Style="{StaticResource OutlineButton}"/>
                        </StackPanel>

                        <DataGrid x:Name="SupplierGrid" Grid.Row="1" ItemsSource="{Binding Suppliers}" Style="{StaticResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding SupplierId}" Width="50"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding SupplierName}" Width="200"/>
                                <DataGridTextColumn Header="Contact" Binding="{Binding Contact}" Width="200"/>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- SETTINGS TAB -->
            <TabItem Header="🏪 Store Settings" Style="{StaticResource ModernTabItem}">
                <Border Style="{StaticResource ModernCard}" Margin="0,10,0,0" Padding="30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Invoice &amp; Report Settings" Style="{StaticResource Heading2}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,25"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Store Name:" VerticalAlignment="Center" Margin="0,0,20,15" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StoreName}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Store Address:" VerticalAlignment="Top" Margin="0,10,20,15" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding StoreAddress}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Store Contact:" VerticalAlignment="Center" Margin="0,0,20,25" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StoreContact}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,25"/>

                        <Button Grid.Row="4" Grid.Column="1" Content="💾 Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
