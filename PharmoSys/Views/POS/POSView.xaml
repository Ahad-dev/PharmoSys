<UserControl x:Class="PharmoSys.Views.POS.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="620" d:DesignWidth="1000"
             FontFamily="Segoe UI">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="💰 Point of Sale (POS)" Style="{StaticResource Heading2}" Foreground="{StaticResource PrimaryBrush}"/>
        </Border>

        <!-- Main Split Panel -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT: Product Catalogue ===== -->
            <Border Grid.Column="0" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="15,12" CornerRadius="10,10,0,0">
                        <TextBlock Text="📋 Products" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextInverseBrush}"/>
                    </Border>

                    <Border Grid.Row="1" Padding="15,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 ToolTip="Search products by name or category"/>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FilteredProducts}"
                              SelectedItem="{Binding SelectedProduct}"
                              Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="90"/>
                            <DataGridTextColumn Header="Price"    Binding="{Binding Price, StringFormat='PKR {0:N0}'}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Stock"    Binding="{Binding StockQuantity}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="3" Padding="15">
                        <Button Content="➕ Add to Cart"
                                Command="{Binding AddToCartCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- GridSplitter Removed. Modern layout doesn't need hard splitters if we have cards. 
                 But wait, I will use a simple Grid space instead. -->

            <!-- ===== RIGHT: Cart ===== -->
            <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="15,12" CornerRadius="10,10,0,0">
                        <TextBlock Text="🛒 Cart" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextInverseBrush}"/>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="CartDataGrid"
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              Style="{StaticResource ModernDataGrid}"
                              IsReadOnly="False"
                              CellEditEnding="CartDataGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"  Binding="{Binding Name}"     Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price"    Binding="{Binding Price, StringFormat='PKR {0:N0}'}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qty"      Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='PKR {0:N0}'}" Width="95" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="{StaticResource BackgroundBrush}" Padding="20,15" BorderThickness="0,1,0,1" BorderBrush="{StaticResource BorderBrush}">
                        <Grid>
                            <TextBlock Text="Total:" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding TotalDisplay}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="15">
                        <Button Content="✅ Checkout" Command="{Binding CheckoutCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="❌ Remove Item" Command="{Binding RemoveItemCommand}"
                                    Style="{StaticResource DangerButton}"/>
                            <Button Grid.Column="2" Content="🗑 Clear Cart" Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource OutlineButton}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
