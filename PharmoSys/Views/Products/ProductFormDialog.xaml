<Window x:Class="PharmoSys.Views.Products.ProductFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding FormTitle}" Height="480" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Border Background="{StaticResource SurfaceBrush}" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="{Binding FormTitle}" Style="{StaticResource Heading2}" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

            <!-- Form Fields -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Product Name *" Style="{StaticResource Subtitle}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                    <TextBlock Text="Category" Style="{StaticResource Subtitle}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                    <TextBlock Text="Price (PKR) *" Style="{StaticResource Subtitle}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                    <TextBlock Text="Stock Quantity" Style="{StaticResource Subtitle}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding StockQuantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                    <TextBlock Text="Expiry Date" Style="{StaticResource Subtitle}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding ExpiryDate}" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Supplier *" Style="{StaticResource Subtitle}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Suppliers}"
                              DisplayMemberPath="SupplierName"
                              SelectedItem="{Binding SelectedSupplier}" Margin="0,0,0,15" Padding="5"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource OutlineButton}" Margin="0,0,10,0" Padding="25,10"/>
                <Button Content="Save" Click="Save_Click" Style="{StaticResource PrimaryButton}" Padding="25,10"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
