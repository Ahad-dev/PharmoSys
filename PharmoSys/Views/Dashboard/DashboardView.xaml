<UserControl x:Class="PharmoSys.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PharmoSys.ViewModels.Dashboard"
             Background="#F5F6FA" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📊 Overview Dashboard" Style="{StaticResource Heading1}" Margin="0,0,0,20"/>

        <!-- Top Metrics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Today's Sales -->
            <Border Grid.Column="0" Style="{StaticResource ModernCard}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Today's Sales" Style="{StaticResource Subtitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalSalesToday, StringFormat='PKR {0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Total Orders -->
            <Border Grid.Column="2" Style="{StaticResource ModernCard}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Orders Today" Style="{StaticResource Subtitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalOrdersToday}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Low Stock -->
            <Border Grid.Column="4" Style="{StaticResource ModernCard}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Low Stock Items" Style="{StaticResource Subtitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LowStockItems}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Expiring Soon -->
            <Border Grid.Column="6" Style="{StaticResource ModernCard}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Expiring Soon" Style="{StaticResource Subtitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ExpiringItems}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alerts Section -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Low Stock Grid -->
            <Border Grid.Column="0" Style="{StaticResource ModernCard}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⚠️ Critical Low Stock" Style="{StaticResource Heading2}" Foreground="{StaticResource WarningBrush}" Margin="0,0,0,15"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding LowStockProducts}" Style="{StaticResource ModernDataGrid}" HeadersVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding StockQuantity, StringFormat='Qty: {0}'}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Expiring Grid -->
            <Border Grid.Column="2" Style="{StaticResource ModernCard}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⏳ Expiring Soon (30 Days)" Style="{StaticResource Heading2}" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,15"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ExpiringProducts}" Style="{StaticResource ModernDataGrid}" HeadersVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding ExpiryDate, StringFormat='dd MMM yyyy'}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
