<UserControl x:Class="PharmoSys.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:PharmoSys.ViewModels.Reports"
             Background="#F5F6FA" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:ReportsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📈 Sales Reports" FontSize="22" FontWeight="Bold" Foreground="#16A085"/>
                    <TextBlock Text="Analyze revenue and top selling products over time." FontSize="13" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Filters -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="110" Margin="0,0,15,0"/>
                    
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="110" Margin="0,0,15,0"/>

                    <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" 
                            Background="#95A5A6" Foreground="White" FontWeight="Bold"
                            Padding="12,8" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                            
                    <Button Content="📄 Export PDF" Command="{Binding ExportPdfCommand}" 
                            Background="#E74C3C" Foreground="White" FontWeight="Bold"
                            Padding="12,8" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                            
                    <Button Content="📊 Export Excel" Command="{Binding ExportExcelCommand}" 
                            Background="#27AE60" Foreground="White" FontWeight="Bold"
                            Padding="12,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top Metrics Cards -->
        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Revenue" FontSize="14" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat='PKR {0:N0}'}" FontSize="28" FontWeight="Bold" Foreground="#16A085" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Orders" FontSize="14" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalSalesCount}" FontSize="28" FontWeight="Bold" Foreground="#2980B9" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Chart and Top Products -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Chart -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Revenue Trend" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding SalesChartSeries}" XAxes="{Binding XAxes}"/>
                </Grid>
            </Border>

            <!-- Top Products -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect><DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Top Selling Products" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TopProducts}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" BorderThickness="0"
                              RowHeight="40" Background="White"
                              AlternatingRowBackground="#F9FFFE">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C3E50"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Sold" Binding="{Binding TotalSold}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#16A085"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
