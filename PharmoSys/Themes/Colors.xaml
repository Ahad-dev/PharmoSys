<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palette -->
    <!-- Primary: Deep Medical Teal -->
    <Color x:Key="PrimaryColor">#16A085</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#128A72"/>

    <!-- Secondary: Dark Slate -->
    <Color x:Key="SecondaryColor">#2C3E50</Color>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#1A252F"/>

    <!-- Backgrounds -->
    <Color x:Key="BackgroundColor">#F4F6F9</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>

    <Color x:Key="SurfaceAltColor">#F9FFFE</Color>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>

    <!-- Accents & Alerts -->
    <Color x:Key="AccentColor">#2ECC71</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#27AE60"/>

    <Color x:Key="DangerColor">#E74C3C</Color>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#C0392B"/>

    <Color x:Key="WarningColor">#F39C12</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#D68910"/>

    <Color x:Key="InfoColor">#2980B9</Color>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#2471A3"/>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#2C3E50</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>

    <Color x:Key="TextSecondaryColor">#7F8C8D</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

    <Color x:Key="TextMutedColor">#BDC3C7</Color>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="TextInverseBrush" Color="#FFFFFF"/>

    <!-- Borders -->
    <Color x:Key="BorderColor">#E0E6ED</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

</ResourceDictionary>
