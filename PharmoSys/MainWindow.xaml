<Window x:Class="PharmoSys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PharmoSys"
        mc:Ignorable="d"
        Title="PharmoSys - Pharmacy Management System" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <!-- Global Styles for Sidebar Buttons -->
    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#117A65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Top Bar -->
            <RowDefinition Height="*"/>
            <!-- Main Area -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Name -->
                <TextBlock Grid.Column="0" Text="🏥 PharmoSys" FontSize="24" FontWeight="Bold" Foreground="#16A085" VerticalAlignment="Center"/>

                <!-- Clock & User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateTime}" FontSize="14" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="{Binding LoggedInUserName}" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SIDEBAR (Medical Green) -->
        <Border Grid.Row="1" Grid.Column="0" Background="#16A085">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,20,0,0">
                    <Button Content="📊 Dashboard" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowDashboardCommand}" Visibility="{Binding IsAdminOrManager, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="💰 POS (Billing)" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowPOSCommand}" Visibility="{Binding IsAdminOrCashier, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="💊 Products" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowProductsCommand}" Visibility="{Binding IsAdminOrManager, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="📦 Stock / Inventory" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowStockCommand}" Visibility="{Binding IsAdminOrManager, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="👥 Manage Users" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowUsersCommand}" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="📈 Reports" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowReportsCommand}" Visibility="{Binding IsAdminOrManager, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Logout Button at bottom -->
                <Button Grid.Row="1" Content="🚪 Logout" Style="{StaticResource SidebarButtonStyle}" Command="{Binding LogoutCommand}" Margin="0,0,0,20" Background="#C0392B"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentView}" Margin="20"/>

    </Grid>
</Window>
