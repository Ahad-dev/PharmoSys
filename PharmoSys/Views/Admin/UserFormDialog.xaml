<Window x:Class="PharmoSys.Views.Admin.UserFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User" Height="360" Width="400" WindowStartupLocation="CenterScreen" Background="#F5F6FA" FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Username:" Grid.Row="0" FontWeight="SemiBold" Foreground="#2C3E50"/>
        <TextBox x:Name="txtUsername" Grid.Row="1" Margin="0,5,0,15" Padding="5"/>

        <TextBlock Text="Full Name:" Grid.Row="2" FontWeight="SemiBold" Foreground="#2C3E50"/>
        <TextBox x:Name="txtFullName" Grid.Row="3" Margin="0,5,0,15" Padding="5"/>

        <TextBlock Text="Phone:" Grid.Row="4" FontWeight="SemiBold" Foreground="#2C3E50"/>
        <TextBox x:Name="txtPhone" Grid.Row="5" Margin="0,5,0,15" Padding="5"/>

        <TextBlock Text="Role (1=Admin, 2=Cashier, 3=Manager):" Grid.Row="6" FontWeight="SemiBold" Foreground="#2C3E50"/>
        <TextBox x:Name="txtRoleId" Grid.Row="7" Margin="0,5,0,15" Padding="5"/>

        <TextBlock Text="Password:" Grid.Row="8" FontWeight="SemiBold" Foreground="#2C3E50"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="9" Margin="0,5,0,20" Padding="5"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Padding="5" Margin="0,0,10,0" Click="BtnCancel_Click" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Save" Width="80" Padding="5" Click="BtnSave_Click" Background="#2ecc71" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
