<UserControl x:Class="PharmoSys.Views.POS.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="620" d:DesignWidth="1000"
             FontFamily="Segoe UI">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <TextBlock Text="💰 Point of Sale (POS)" FontSize="22" FontWeight="Bold" Foreground="#16A085"/>
        </Border>

        <!-- Main Split Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT: Product Catalogue ===== -->
            <Border Grid.Column="0" Background="White" Margin="0,10,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#16A085" Padding="14,10">
                        <TextBlock Text="📋 Products" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <Border Grid.Row="1" Padding="12,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="14" BorderBrush="#BDC3C7"
                                 ToolTip="Search products by name or category"/>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FilteredProducts}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" BorderThickness="0"
                              RowHeight="38" Background="White"
                              AlternatingRowBackground="#F9FFFE">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1ABC9C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="90"/>
                            <DataGridTextColumn Header="Price"    Binding="{Binding Price, StringFormat='PKR {0:N0}'}" Width="90"/>
                            <DataGridTextColumn Header="Stock"    Binding="{Binding StockQuantity}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="3" Content="➕ Add to Cart"
                            Command="{Binding AddToCartCommand}"
                            Background="#16A085" Foreground="White"
                            FontSize="15" FontWeight="Bold"
                            Height="46" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- ===== RIGHT: Cart ===== -->
            <Border Grid.Column="2" Background="White" Margin="0,10,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2C3E50" Padding="14,10">
                        <TextBlock Text="🛒 Cart" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="CartDataGrid"
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" BorderThickness="0"
                              RowHeight="38" Background="White"
                              AlternatingRowBackground="#FFF9F9"
                              CellEditEnding="CartDataGrid_CellEditEnding">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C3E50"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"  Binding="{Binding Name}"     Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price"    Binding="{Binding Price, StringFormat='PKR {0:N0}'}" Width="80" IsReadOnly="True"/>
                            <!-- Qty is editable directly -->
                            <DataGridTemplateColumn Header="Qty" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Quantity}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="#FFFBE6"
                                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='PKR {0:N0}'}" Width="95" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#ECF0F1" Padding="16,12" Margin="0,4,0,0">
                        <Grid>
                            <TextBlock Text="Total:" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding TotalDisplay}" FontSize="22" FontWeight="Bold"
                                       Foreground="#16A085" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="8,8,8,8">
                        <Button Content="✅ Checkout" Command="{Binding CheckoutCommand}"
                                Background="#16A085" Foreground="White"
                                FontSize="16" FontWeight="Bold"
                                Height="46" BorderThickness="0" Cursor="Hand" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="❌ Remove Item" Command="{Binding RemoveItemCommand}"
                                    Background="#E74C3C" Foreground="White"
                                    FontWeight="SemiBold" Height="36" BorderThickness="0"
                                    Cursor="Hand" Width="140" Margin="0,0,6,0"/>
                            <Button Content="🗑 Clear Cart" Command="{Binding ClearCartCommand}"
                                    Background="#95A5A6" Foreground="White"
                                    FontWeight="SemiBold" Height="36" BorderThickness="0"
                                    Cursor="Hand" Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
